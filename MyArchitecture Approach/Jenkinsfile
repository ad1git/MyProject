pipeline {
    agent any

    tools {
        maven 'Maven3'
        jdk 'JDK11'
    }

    parameters {
        string(name: 'ENV', defaultValue: 'qa', description: 'Environment')
        string(name: 'TAG', defaultValue: 'smoke', description: 'Test Tag (smoke/regression/all)')
    }

    stages {
        stage('Checkout') {
            steps {
                git 'https://github.com/your-username/your-repo.git'
            }
        }

        stage('Build') {
            steps {
                bat 'mvn clean compile'
            }
        }

        stage('Smoke Test') {
            when {
                expression { params.TAG == 'smoke' || params.TAG == 'all' }
            }
            steps {
                echo "Running Smoke Tests on ${params.ENV} environment..."
                bat "mvn test -Denv=%ENV% -Dgroups=smoke"
            }
        }

        stage('Regression Test') {
            when {
                expression { params.TAG == 'regression' || params.TAG == 'all' }
            }
            steps {
                echo "Running Regression Tests on ${params.ENV} environment..."
                bat "mvn test -Denv=%ENV% -Dgroups=regression"
            }
        }

        stage('HTML Report') {
            steps {
                echo 'Generating HTML report...'
                bat 'mvn surefire-report:report'
                archiveArtifacts artifacts: 'target/site/surefire-report.html', fingerprint: true
            }
        }
    }

    post {
        always {
            junit '**/target/surefire-reports/*.xml'
        }
        failure {
            echo 'Tests Failed ❌'
        }
        success {
            echo 'Tests Passed ✅'
        }
    }
}
